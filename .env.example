# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API (used by analysis/ai_analyst.py for signal generation)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alpaca paper trading API (used by trading/alpaca_client.py)
APCA_API_KEY_ID=your-alpaca-key-id-here
APCA_API_SECRET_KEY=your-alpaca-secret-key-here
APCA_API_BASE_URL=https://paper-api.alpaca.markets
